# ── Entorno ───────────────────────────────────────────────────────────────────
# 'development' permite el JWT_SECRET default (solo para dev local).
# En producción setea APP_ENV=production y un JWT_SECRET fuerte — el backend
# se niega a arrancar si APP_ENV=production y JWT_SECRET es débil o vacío.
APP_ENV=development

# ── Origen CORS permitido (producción) ────────────────────────────────────────
# En dev se permiten localhost automáticamente.
# En producción setea esto al dominio real de la app (sin slash final).
# Ejemplo: ALLOWED_ORIGIN=https://sigespu.lota.cl
ALLOWED_ORIGIN=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sigespu
DB_USER=sigespu_user
DB_PASSWORD=secret_password
# Tamaño del pool de conexiones. 10-15 alcanza para ~20 usuarios concurrentes.
DB_POOL_SIZE=15

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# En producción genera con:  openssl rand -hex 32
# Mínimo 32 caracteres si APP_ENV=production (el backend valida al arrancar).
JWT_SECRET=dev_only_jwt_secret_DO_NOT_USE_IN_PROD
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
# INFO | WARNING | SEVERE — en producción se recomienda WARNING para
# reducir ruido de tráfico normal.
LOG_LEVEL=INFO

# ── Nginx ─────────────────────────────────────────────────────────────────────
DOMAIN=localhost

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_USER=sigespulota@gmail.com
SMTP_PASS=<app-password-16-chars-sin-espacios>

# ── Railway (producción) ──────────────────────────────────────────────────────
# Railway inyecta DATABASE_URL y REDIS_URL automáticamente al conectar los
# plugins de Postgres y Redis. No los setees manualmente en Railway dashboard —
# ya están. Solo son necesarios aquí si corres el backend sin Railway.
DATABASE_URL=postgresql://user:password@host:port/dbname
REDIS_URL=redis://default:password@host:port

# Railway lo inyecta automáticamente. No necesitas setearlo.
# RAILWAY_ENVIRONMENT=production

# ── Scraper ───────────────────────────────────────────────────────────────────
# true = corre scrape completo de historial al arrancar (usar solo en primer deploy).
# Setear en Railway dashboard, luego remover después del primer run.
RUN_INITIAL_SCRAPE=false
