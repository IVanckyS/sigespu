<?xml version="1.0" encoding="utf-8"?>
<!--
  SIGESPU Horizonte emblem — foreground layer for adaptive icon.
  Geometry mirrors _HorizonteEmblemPainter (sigespu_emblem.dart) scaled
  from the 64×64 logical grid to the 108×108 adaptive-icon viewport.
  Background (#1C1917) is supplied by the ic_launcher_background color layer.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sun — circle at (54, 37.125), r = 10.125 -->
    <path
        android:fillColor="#F97316"
        android:pathData="M43.875,37.125
                          A10.125,10.125 0 1 0 64.125,37.125
                          A10.125,10.125 0 1 0 43.875,37.125 Z" />

    <!-- Arc 1 — sand, 55 % opacity, M(16.875,70.875) Q(54,50.625) (91.125,70.875) -->
    <path
        android:strokeColor="#8CFED7AA"
        android:strokeWidth="3.7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16.875,70.875 Q54,50.625 91.125,70.875" />

    <!-- Arc 2 — sand, 80 % opacity, M(16.875,81) Q(54,57.375) (91.125,81) -->
    <path
        android:strokeColor="#CCFED7AA"
        android:strokeWidth="4.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16.875,81 Q54,57.375 91.125,81" />

    <!-- Arc 3 — accent orange, M(10.125,91.125) Q(54,64.125) (97.875,91.125) -->
    <path
        android:strokeColor="#EA580C"
        android:strokeWidth="5.1"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M10.125,91.125 Q54,64.125 97.875,91.125" />

</vector>
